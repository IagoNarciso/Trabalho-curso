import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        
        Scanner scanner = new Scanner(System.in);

        System.out.print("Digite a sua idade: ");
        
        if (scanner.hasNextInt()) {
            int numero = scanner.nextInt();
            
            if (numero >= 18) {
                System.out.println("Você tem " + numero + " anos sendo assim, é maior de idade");
            } else if (numero < 18) {
                System.out.println("Você tem " + numero + " anos sendo assim, é menor de idade");
            }
        }
        scanner.close();
    }    
}
